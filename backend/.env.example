# Copy to .env locally. On Render, add these in the service → Environment tab.

# Required
PORT=5000
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/auctionnepal?retryWrites=true&w=majority

JWT_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-different-long-random-string

# Comma-separated browser origins allowed for CORS + Socket.IO (no trailing slashes)
# Production Vercel app + optional preview URLs:
# First URL is used for password-reset links when FRONTEND_URL lists several origins.
FRONTEND_URL=https://your-app.vercel.app,http://localhost:3000

# Cloudinary (profile pictures, uploads) — leave unset if unused
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (password reset) — leave unset if unused
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
